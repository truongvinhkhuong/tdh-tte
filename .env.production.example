# ============================================
# TTE Monorepo - Production Environment
# ============================================
# Copy this to .env on production server

# ============================================
# DATABASE
# ============================================
DB_NAME=tte_cms
DB_USER=tte_prod
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ============================================
# REDIS
# ============================================
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ============================================
# PAYLOAD CMS
# ============================================
PAYLOAD_SECRET=GENERATE_WITH_openssl_rand_-base64_32
PAYLOAD_PUBLIC_SERVER_URL=https://cms.toanthang.vn
PAYLOAD_API_KEY=

# ============================================
# CLOUDINARY (Media Storage)
# ============================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# AI PROVIDERS
# ============================================
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# ============================================
# AI ENGINE (RAG Chatbot)
# ============================================
LLAMA_CLOUD_API_KEY=

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=tte_knowledge_base

# Google Drive (Optional - for auto-sync)
GOOGLE_DRIVE_FOLDER_ID=

# AI Engine Config
AI_ENGINE_DEBUG=false
AI_ENGINE_LOG_LEVEL=INFO

# ============================================
# APPLICATION URLS
# ============================================
FRONTEND_URL=https://toanthang.vn
CMS_URL=https://cms.toanthang.vn
BACKEND_URL=https://api.toanthang.vn

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=production
