# ============================================
# TTE Monorepo - Environment Variables Example
# ============================================
# Copy this file to .env.local and fill in the values
# Ports adjusted to avoid conflicts with other services

# ============================================
# DATABASE (Port 5434)
# ============================================
DB_NAME=tte_cms
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5434/tte_cms

# ============================================
# REDIS (Port 6381)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@localhost:6381

# ============================================
# PAYLOAD CMS (Port 4001)
# ============================================
PAYLOAD_SECRET=your_very_long_secret_key_here_min_32_chars
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:4001
PAYLOAD_API_KEY=your_payload_api_key_here

# ============================================
# CLOUDINARY (Media Storage)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# AI PROVIDERS
# ============================================
DEEPSEEK_API_KEY=your_deepseek_api_key
OPENAI_API_KEY=sk-your_openai_api_key

# ============================================
# APPLICATION URLS (Updated Ports)
# ============================================
FRONTEND_URL=http://localhost:4000
NEXT_PUBLIC_CMS_URL=http://localhost:4001
CMS_URL=http://localhost:4001
BACKEND_URL=http://localhost:4002
AI_ENGINE_URL=http://localhost:4003

# ============================================
# ENABLE CMS INTEGRATION
# ============================================
NEXT_PUBLIC_USE_CMS=false

# ============================================
# CHATBOT SECURITY (Rate Limiting & Optimization)
# ============================================
# Rate limiting per IP per minute
CHATBOT_RATE_LIMIT_IP=5
# Rate limiting per session per hour
CHATBOT_RATE_LIMIT_SESSION=20
# Global rate limit per minute (protect AI Engine)
CHATBOT_RATE_LIMIT_GLOBAL=100
# Max question length in characters
CHATBOT_MAX_QUESTION_LENGTH=500
# Session TTL in seconds (default 30 min)
CHATBOT_SESSION_TTL=1800
# Max conversation turns to keep in context
CHATBOT_MAX_HISTORY_TURNS=3
# Response cache TTL in seconds (default 24 hours)
CHATBOT_CACHE_TTL=86400
# Enable/disable response caching
CHATBOT_CACHE_ENABLED=true
