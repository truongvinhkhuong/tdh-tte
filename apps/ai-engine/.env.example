# Environment Configuration for AI Engine
# Copy this file to .env and fill in the values

# ===========================================
# Required: API Keys
# ===========================================
DEEPSEEK_API_KEY=sk-your-deepseek-key
OPENAI_API_KEY=sk-your-openai-key
LLAMA_CLOUD_API_KEY=llx-your-llamaparse-key
VOYAGEAI_API_KEY=pa-your-voyageai-key

# ===========================================
# Required: Qdrant Cloud
# ===========================================
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=tte_knowledge_base

# ===========================================
# Optional: Redis (for caching/queue)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# Optional: Google Drive Integration
# ===========================================
# Create a service account and share the folder with it
# Download credentials JSON and place in credentials/service-account.json
GOOGLE_DRIVE_FOLDER_ID=your-folder-id
GOOGLE_CREDENTIALS_PATH=credentials/service-account.json

# ===========================================
# Service Configuration
# ===========================================
DEBUG=false
LOG_LEVEL=INFO

# ===========================================
# RAG Configuration
# ===========================================
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
EMBEDDING_PROVIDER=voyageai
EMBEDDING_MODEL=voyage-3.5-lite
RETRIEVAL_TOP_K=15
RERANK_TOP_N=5
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
