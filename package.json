{
  "name": "tte-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "dev:web": "turbo dev --filter=@tte/web",
    "dev:cms": "turbo dev --filter=@tte/cms",
    "dev:backend": "turbo dev --filter=@tte/backend",
    "dev:ai": "turbo dev --filter=@tte/ai-engine",
    "build:web": "turbo build --filter=@tte/web",
    "build:cms": "turbo build --filter=@tte/cms",
    "build:backend": "turbo build --filter=@tte/backend",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "db:migrate": "turbo db:migrate --filter=@tte/cms",
    "db:seed": "turbo db:seed --filter=@tte/cms"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}